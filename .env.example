# MongoDB Atlas URI (required for Render deployment)
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?appName=MyApp
DATABASE_NAME=adaptive_diagnostic

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=Adaptive-Diagnostist
